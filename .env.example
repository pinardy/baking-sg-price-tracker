# Server port (Vite dev server proxies /api here)
PORT=3001

# Daily price fetch schedule (node-cron syntax, local time)
FETCH_CRON=0 8 * * *

# Provider filtering (comma-separated provider ids):
#   FETCH_PROVIDERS — allowlist; only these run (wins over SKIP_PROVIDERS)
#   SKIP_PROVIDERS  — denylist
# With neither set, residential-only providers (bakewithyen) are skipped
# automatically when CI=true (GitHub Actions).
#FETCH_PROVIDERS=
#SKIP_PROVIDERS=
